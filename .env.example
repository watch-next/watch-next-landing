# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Download URLs (fallback if database is not configured)
# These are used when Supabase is not configured or as fallback
VITE_DOWNLOAD_WINDOWS=https://example.com/download/windows
VITE_DOWNLOAD_ANDROID=https://example.com/download/android
VITE_DOWNLOAD_MACOS=https://example.com/download/macos

# Analytics Providers (configure as needed)
VITE_ANALYTICS_PROVIDER=
# Google Analytics - Measurement ID from GA4 property
VITE_GOOGLE_ANALYTICS_ID=

# Plausible Analytics - Domain from your Plausible site
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_SELF_HOSTED=false
VITE_PLAUSIBLE_HOST=

# PostHog - Project API key and optional self-hosted URL
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=