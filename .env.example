# Vite Environment Variables
# Copy this file to .env and fill in your values

# ==============================================================================
# Application
# ==============================================================================
# VITE_APP_URL=https://watchnext.app
# VITE_APP_NAME=Watch Next

# ==============================================================================
# Supabase (Required for production)
# Required for: Waitlist, Feedback, Admin Panel, Blog
# ==============================================================================
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# For admin setup, also configure in Supabase Dashboard:
# - Auth > Users > Add user
# - Run the SQL from docs/ to set is_admin flag
# - Set SUPABASE_SERVICE_ROLE_KEY for set-admin script

# ==============================================================================
# TMDB API (Frontend - Public)
# Required for: Movies feature (Phase 1+)
# ==============================================================================
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_URL=https://image.tmdb.org
VITE_TMDB_LANGUAGE=en-US
VITE_TMDB_REGION=US

# ==============================================================================
# TMDB API (Server - Secret)
# Required for: Vercel Serverless Function (api/tmdb) and local dev proxy
# NEVER expose this in the frontend bundle!
# ==============================================================================
TMDB_API_KEY=your-tmdb-api-key-here
TMDB_API_BASE=https://api.themoviedb.org/3

# Get your API key from: https://www.themoviedb.org/settings/api

# ==============================================================================
# Google Analytics (Optional)
# ==============================================================================
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ==============================================================================
# Production Domain
# ==============================================================================
# VITE_PRODUCTION_DOMAIN=watchnext.app